# ============================================================
#  PROPERTY VIEWING SYSTEM — CONFIGURATION
#  Fill in your details, save the file, then deploy.
#  You only need to edit THIS file — nothing else.
# ============================================================

# --- YOUR AGENCY DETAILS ---
AGENCY_NAME=Sunrise Property Group
AGENCY_EMAIL=viewings@youragency.com
AGENCY_PHONE=+27 21 000 0000
AGENCY_TAGLINE=Request a property viewing online

# --- PROPERTY DETAILS ---
# This is the property shown on the request page
PROPERTY_TITLE=3 Bedroom Home in Pinelands
PROPERTY_DESCRIPTION=Spacious family home with a garden, double garage, and open-plan kitchen. Close to top schools and transport links.
PROPERTY_ADDRESS=12 Oak Street, Pinelands, Cape Town
PROPERTY_PRICE=R 2 450 000
# Optional: paste a property image URL here (from Property24, your website, etc.)
PROPERTY_IMAGE_URL=

# --- ADMIN ACCESS ---
# This is the password you use to log into the agent dashboard
# CHANGE THIS before going live!
ADMIN_PASSWORD=agent2024

# --- VIEWING TIMES TO OFFER ---
# These are the time options shown to buyers on the request form
VIEWING_TIMES=08:00,09:00,10:00,11:00,12:00,13:00,14:00,15:00,16:00,17:00

# --- HOW FAR AHEAD CAN BUYERS REQUEST? ---
# Number of days into the future a buyer can pick
ADVANCE_BOOKING_DAYS=30

# --- EMAIL (for sending confirmations) ---
# Get free SMTP credentials at brevo.com (300 emails/day free)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-login@brevo.com
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=Sunrise Property Group
SMTP_FROM_EMAIL=viewings@youragency.com

# --- SERVER ---
PORT=3000
PUBLIC_URL=http://localhost:3000
